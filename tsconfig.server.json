{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@contracts/*": ["./contracts/*"],
      "@db/*": ["./db/*"],
      "@api/*": ["./api/*"],
      "@srclib/*": ["./src/lib/*"],
      "@components/*": ["./src/components/*"],
      "@pages/*": ["./src/pages/*"],
      "@tabs/*": ["./src/tabs/*"],
      "@types/*": ["./src/types/*"],
      "@apilib/*": ["./api/lib/*"],
      "@queries/*": ["./api/queries/*"],
      "@routers/*": ["./api/routers/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@/components/xtreino": ["./src/components/xtreino/index.ts"],
    }
  },
  "include": ["api", "contracts", "db"]
}
